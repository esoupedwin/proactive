# Copy this file to .env.local and fill in the values.
# See SETUP.md for a step-by-step walkthrough.

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# OpenAI → https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: override the model used for search + summarization (default: gpt-5-mini)
# OPENAI_MODEL=gpt-5-mini

# Optional: comma-separated list of Google account emails allowed to use the app.
# Leave unset to allow anyone to sign in.
# ALLOWED_EMAILS=you@example.com,friend@example.com
